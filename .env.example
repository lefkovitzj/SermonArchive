# Database configuration details.
DB_URL=jdbc:YOUR_DATABASE_URL
DB_USERNAME=YOUR_DATABASE_USERNAME
DB_PASSWORD=YOUR_PASSWORD

# Logging profile accepts 'local' or 'aws'.
LOGGING_PROFILE=local

# Cryptographic secret for JWT generation and validation.
JWT_SECRET=YOUR_32_BYTE_KEY

# AWS S3 (or S3-compatible object store) configuration details.
S3_ENDPOINT=YOUR_S3_ENDPOINT
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY
S3_BUCKET_NAME=YOUR_S3_BUCKET_NAME
S3_REGION=YOUR_S3_REGION
S3_S3_PUBLIC_URL_PATTERN=http://{bucket}.YOUR_PUBLIC_URL_PATTERN/{key}